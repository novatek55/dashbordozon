# Ozon API Credentials
OZON_CLIENT_ID=your_client_id_here
OZON_API_KEY=your_api_key_here
OZON_PERFORMANCE_CLIENT_ID=your_performance_client_id
OZON_PERFORMANCE_CLIENT_SECRET=your_performance_client_secret
WB_API_KEY=your_wb_finance_api_key

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ozon_analytics
# server = real/current database. local_snapshot/dev_fixture must be explicit for local data.
DB_SOURCE_MODE=dev_fixture
ALLOW_LOCAL_DATABASE=true
EXPECTED_DB_HOST=

# Sync Settings
SYNC_DAYS_BACK=30
BATCH_SIZE=1000
MAX_CONCURRENT_REQUESTS=5
OZON_HTTP_TIMEOUT_TOTAL=180
OZON_HTTP_TIMEOUT_CONNECT=30
OZON_HTTP_TIMEOUT_SOCK_READ=120
OZON_TRUST_ENV_PROXY=true
OZON_FORCE_IPV4=false
CAMPAIGNS_REFRESH_HOURS=6
CAMPAIGN_REPORT_BATCH_SIZE=10
CAMPAIGN_REPORT_CREATE_ATTEMPTS=6
CAMPAIGN_REPORT_ACTIVE_LIMIT_DELAY_SECONDS=120

# Supply (draft create/timeslots)
# Default crossdock pair (fallback for non-Moscow clusters)
OZON_CROSSDOCK_SELLER_WAREHOUSE_ID=
OZON_CROSSDOCK_DROPOFF_WAREHOUSE_ID=
# Optional override for SPB macro-cluster (macrolocal_cluster_id=4007)
OZON_CROSSDOCK_SPB_SELLER_WAREHOUSE_ID=
OZON_CROSSDOCK_SPB_DROPOFF_WAREHOUSE_ID=
# Anti-429 tuning for timeslots
SUPPLY_TIMESLOT_STAGGER_DELAY_SEC=0.25
SUPPLY_TIMESLOT_RETRY_DELAY_SEC=2.5
SUPPLY_TIMESLOT_RETRY_BACKOFF=1.7
SUPPLY_TIMESLOT_RETRY_MAX_DELAY_SEC=45
# DIRECT warehouse pre-filtering before timeslot requests
SUPPLY_TIMESLOT_EXCLUDE_MATRIX_DIRECT=1
SUPPLY_TIMESLOT_INCLUDE_NOT_AVAILABLE_RANK_DIRECT=1
SUPPLY_TIMESLOT_MAX_RANK_DIRECT=6
SUPPLY_TIMESLOT_SKIP_KGT_WAREHOUSES_DIRECT=0
SUPPLY_TIMESLOT_EXCLUDE_NAME_PATTERNS_DIRECT=
SUPPLY_TIMESLOT_INCLUDE_NAME_PATTERNS_DIRECT=

# Logging
LOG_LEVEL=INFO
