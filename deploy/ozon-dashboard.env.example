# Copy to /etc/ozon-dashboard.env on the server and fill secrets there.
# Do not commit real tokens/passwords.

DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=18088
DASHBOARD_INTERNAL_BASE_URL=http://127.0.0.1:18088

DATABASE_URL=postgresql+asyncpg://ozon_user:CHANGE_ME@127.0.0.1:5432/ozon_analytics
DB_SOURCE_MODE=server
# Server deploy may use a DB on localhost. Keep this true only in the server env file.
ALLOW_LOCAL_DATABASE=true
EXPECTED_DB_HOST=127.0.0.1

OZON_CLIENT_ID=CHANGE_ME
OZON_API_KEY=CHANGE_ME
OZON_PERFORMANCE_CLIENT_ID=
OZON_PERFORMANCE_CLIENT_SECRET=
WB_API_KEY=
WB_ADVERTISING_API_KEY=

SYNC_DAYS_BACK=30
REPORT_POSTINGS_DAYS_BACK=60
BATCH_SIZE=1000
MAX_CONCURRENT_REQUESTS=3
OZON_HTTP_TIMEOUT_TOTAL=180
OZON_HTTP_TIMEOUT_CONNECT=30
OZON_HTTP_TIMEOUT_SOCK_READ=120
OZON_TRUST_ENV_PROXY=true
OZON_FORCE_IPV4=false
ASYNC_REPORT_REFRESH_HOURS=24
CAMPAIGNS_REFRESH_HOURS=6
CAMPAIGN_REPORT_BATCH_SIZE=10
CAMPAIGN_REPORT_CREATE_ATTEMPTS=6
CAMPAIGN_REPORT_ACTIVE_LIMIT_DELAY_SECONDS=120
FBS_WAREHOUSE_IDS=
LOG_LEVEL=INFO
